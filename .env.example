# Copy to .env and fill in values.

HF_TOKEN=
FFMPEG_BIN=C:\ffmpeg\bin\ffmpeg.exe

# Optional: keep all Hugging Face models inside the project (easier to copy offline)
# HF_HOME=D:\Projects\ArabicSpeechToText\models\huggingface

# After prefetch_models.py on an online PC, set on the air-gapped machine:
# HF_HUB_OFFLINE=1

# Local typo-fix model (download once: python prefetch_models.py)
# TEXT_FIX_MODEL=Qwen/Qwen2.5-0.5B-Instruct
# TEXT_FIX_DEVICE=cpu

# Diarization tuning (optional)
# DIARIZATION_CLUSTERING_THRESHOLD=0.7
# DIARIZATION_MERGE_GAP=0.35
# DIARIZATION_MIN_TURN=0.5

# Server (upload tab + playback)
GRADIO_SERVER_NAME=172.24.4.204
GRADIO_SERVER_PORT=7860

# HTTPS — self-signed cert in .certs/ (browser will show a warning once)
GRADIO_ENABLE_SSL=1
SSL_CN=172.24.4.204
# Or use your own certificate:
# SSL_CERTFILE=C:\path\to\cert.pem
# SSL_KEYFILE=C:\path\to\key.pem
